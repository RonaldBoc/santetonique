---
import logo from '../assets/logos/logo_sante_tonique.svg';

const year = new Date().getFullYear();

const links = [
  { href: '/',             label: 'Accueil' },
  { href: '/a-propos',     label: 'À propos' },
  { href: '/nos-produits', label: 'Nos produits' },
  { href: '/contact',      label: 'Contact' },
  { href: '/blog',         label: 'Blog' },
];
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__brand">
      <a href="/" aria-label="Santé Tonique — Accueil">
        <img src={logo.src} alt="Santé Tonique" width="120" height="42" class="footer__logo" />
      </a>
      <p class="footer__tagline">
        Votre santé naturelle en Martinique,<br />
        <em>en famille depuis 2001</em>
      </p>
      <p class="footer__values">
        <span class="accent">✦</span> Intégrité &nbsp;·&nbsp; Bienveillance &nbsp;·&nbsp; Naturel
      </p>
    </div>

    <nav class="footer__nav" aria-label="Navigation pied de page">
      {links.map(({ href, label }) => (
        <a href={href} class="footer__link">{label}</a>
      ))}
    </nav>

    <address class="footer__contact">
      <p class="footer__contact-label">Boutique</p>
      <p>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        Fort-de-France, Martinique
      </p>
      <p>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 10.85 19.79 19.79 0 0 1 1.08 2.18 2 2 0 0 1 3.06.02h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 7.91a16 16 0 0 0 5 5l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 13.92v3z"/></svg>
        <a href="tel:+596596000000">+596 596 XX XX XX</a>
      </p>
      <p>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        <a href="mailto:contact@santetonique.com">contact@santetonique.com</a>
      </p>
    </address>
  </div>

  <div class="footer__bottom">
    <p>© {year} Santé Tonique · Fort-de-France, Martinique · Tous droits réservés</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--bark);
    color: rgba(245, 237, 217, 0.75);
    font-family: 'Jost', sans-serif;
    font-size: 0.88rem;
    position: relative;
    overflow: hidden;
  }
  .footer::before {
    content: '';
    position: absolute;
    left: -80px; top: -80px;
    width: 400px; height: 400px;
    background: radial-gradient(ellipse, rgba(212, 168, 82, 0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 5rem;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1.2fr;
    gap: 4rem;
    position: relative;
  }

  .footer__logo {
    filter: brightness(0) invert(1);
    opacity: 0.85;
    margin-bottom: 1.2rem;
  }

  .footer__tagline {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1rem;
    color: rgba(245, 237, 217, 0.6);
    margin: 0 0 1rem;
    line-height: 1.6;
  }
  .footer__tagline em {
    color: var(--gold);
    font-style: italic;
  }

  .footer__values {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(245, 237, 217, 0.45);
    margin: 0;
  }
  .accent {
    color: var(--gold);
  }

  .footer__nav {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 0.2rem;
  }

  .footer__link {
    font-size: 0.85rem;
    color: rgba(245, 237, 217, 0.6);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer__link:hover {
    color: var(--gold);
  }

  .footer__contact {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding-top: 0.2rem;
  }
  .footer__contact-label {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    margin: 0 0 0.2rem;
    font-weight: 500;
  }
  .footer__contact p {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    color: rgba(245, 237, 217, 0.65);
  }
  .footer__contact a {
    color: rgba(245, 237, 217, 0.65);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer__contact a:hover {
    color: var(--gold);
  }
  .footer__contact svg {
    flex-shrink: 0;
    opacity: 0.6;
  }

  .footer__bottom {
    border-top: 1px solid rgba(245, 237, 217, 0.08);
    text-align: center;
    padding: 1.2rem 5rem;
    font-size: 0.78rem;
    color: rgba(245, 237, 217, 0.35);
  }
  .footer__bottom p { margin: 0; }

  @media (max-width: 900px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding: 3rem 1.5rem;
    }
    .footer__bottom {
      padding: 1.2rem 1.5rem;
    }
  }
</style>
