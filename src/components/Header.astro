---
import logo from '../assets/logos/logo_sante_tonique.svg';

const navLinks = [
  { href: '/',             label: 'Accueil' },
  { href: '/a-propos',     label: 'À propos' },
  { href: '/nos-produits', label: 'Nos produits' },
  { href: '/blog',         label: 'Blog' },
];

const currentPath = Astro.url.pathname;
---

<header class="nav" role="banner">
  <div class="nav__inner">
    <a href="/" class="nav__logo" aria-label="Santé Tonique — Accueil">
      <img src={logo.src} alt="Santé Tonique" width="140" height="48" />
    </a>

    <nav class="nav__links" aria-label="Navigation principale">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'nav__link',
            {
              'nav__link--active':
                currentPath === href ||
                (href !== '/' && currentPath.startsWith(href)),
            },
          ]}
        >
          {label}
        </a>
      ))}
      <a href="/contact" class="nav__cta">Nous contacter</a>
    </nav>

    <button
      class="nav__burger"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="4" x2="20" y1="6" y2="6"/>
        <line x1="4" x2="20" y1="12" y2="12"/>
        <line x1="4" x2="20" y1="18" y2="18"/>
      </svg>
    </button>
  </div>

  <div class="nav__mobile" id="mobile-menu" aria-hidden="true">
    <nav aria-label="Menu mobile">
      {navLinks.map(({ href, label }) => (
        <a href={href} class="nav__mobile-link">{label}</a>
      ))}
      <a href="/contact" class="nav__mobile-link nav__mobile-cta">Nous contacter</a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(251, 246, 236, 0.88);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(61, 43, 31, 0.08);
    transition: box-shadow 0.3s;
  }
  .nav.scrolled {
    box-shadow: 0 2px 24px rgba(61, 43, 31, 0.09);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 4rem;
    height: 72px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .nav__logo img {
    height: 42px;
    width: auto;
    display: block;
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .nav__link {
    font-family: 'Jost', sans-serif;
    font-size: 0.82rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--bark);
    text-decoration: none;
    position: relative;
    transition: color 0.2s;
  }
  .nav__link::after {
    content: '';
    position: absolute;
    bottom: -3px; left: 0;
    width: 0; height: 1.5px;
    background: var(--honey);
    transition: width 0.25s ease;
  }
  .nav__link:hover,
  .nav__link--active { color: var(--honey); }
  .nav__link:hover::after,
  .nav__link--active::after { width: 100%; }

  .nav__cta {
    font-family: 'Jost', sans-serif;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--honey);
    border: 1.5px solid var(--honey);
    padding: 0.48rem 1.2rem;
    border-radius: 2px;
    text-decoration: none;
    transition: background 0.25s, color 0.25s;
  }
  .nav__cta:hover { background: var(--honey); color: #fff; }

  .nav__burger {
    display: none;
    background: none;
    border: none;
    color: var(--bark);
    cursor: pointer;
    padding: 0.25rem;
  }

  .nav__mobile {
    display: none;
    flex-direction: column;
    background: var(--ivory);
    border-top: 1px solid rgba(61, 43, 31, 0.08);
    padding: 0 1.5rem;
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.35s ease, padding 0.35s ease;
  }
  .nav__mobile.open {
    max-height: 360px;
    padding: 1rem 1.5rem 1.5rem;
  }

  .nav__mobile-link {
    font-family: 'Jost', sans-serif;
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--bark);
    text-decoration: none;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(61, 43, 31, 0.07);
    display: block;
    transition: color 0.2s;
  }
  .nav__mobile-link:last-child { border-bottom: none; }
  .nav__mobile-link:hover { color: var(--honey); }

  .nav__mobile-cta {
    margin-top: 0.5rem;
    color: var(--honey);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.8rem;
    border: none;
  }

  @media (max-width: 900px) {
    .nav__inner { padding: 0 1.5rem; }
    .nav__links { display: none; }
    .nav__burger { display: flex; }
    .nav__mobile { display: flex; }
  }
</style>

<script>
  // Scroll shadow — only needs to bind once
  const nav = document.querySelector('.nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 10);
  }, { passive: true });

  function initNav() {
    const burger = document.querySelector('.nav__burger') as HTMLButtonElement | null;
    const menu = document.getElementById('mobile-menu');

    // Close mobile menu on navigation
    menu?.classList.remove('open');
    burger?.setAttribute('aria-expanded', 'false');
    menu?.setAttribute('aria-hidden', 'true');

    burger?.addEventListener('click', () => {
      const open = menu?.classList.toggle('open');
      burger.setAttribute('aria-expanded', open ? 'true' : 'false');
      menu?.setAttribute('aria-hidden', open ? 'false' : 'true');
    });
  }

  document.addEventListener('astro:page-load', initNav);
</script>
