---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Contactez Santé Tonique — boutique de santé naturelle à Fort-de-France, Martinique. Adresse, téléphone, email et formulaire de contact."
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="page-hero__inner">
      <div class="eyebrow">Restons en contact</div>
      <h1>Venez nous <em>rendre visite</em></h1>
      <p class="page-hero__sub">
        Notre équipe est à votre disposition pour répondre à toutes vos questions.
      </p>
    </div>
  </section>

  <!-- Contenu principal -->
  <section class="section">
    <div class="container">
      <div class="contact-grid">

        <!-- Informations -->
        <div class="contact-info reveal">
          <h2>Nos <em>coordonnées</em></h2>

          <div class="info-block">
            <span class="info-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </span>
            <div>
              <strong>Adresse</strong>
              <address>
                Santé Tonique<br />
                Fort-de-France<br />
                97200 Martinique
              </address>
            </div>
          </div>

          <div class="info-block">
            <span class="info-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 10.85 19.79 19.79 0 0 1 1.08 2.18 2 2 0 0 1 3.06.02h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 7.91a16 16 0 0 0 5 5l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 13.92v3z"/></svg>
            </span>
            <div>
              <strong>Téléphone</strong>
              <a href="tel:+596596000000">+596 596 XX XX XX</a>
            </div>
          </div>

          <div class="info-block">
            <span class="info-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </span>
            <div>
              <strong>Email</strong>
              <a href="mailto:contact@santetonique.com">contact@santetonique.com</a>
            </div>
          </div>

          <div class="info-block">
            <span class="info-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </span>
            <div>
              <strong>Horaires d'ouverture</strong>
              <table class="horaires">
                <tr><td>Lundi – Vendredi</td><td>8h00 – 17h00</td></tr>
                <tr><td>Samedi</td><td>8h00 – 13h00</td></tr>
                <tr><td>Dimanche</td><td>Fermé</td></tr>
              </table>
            </div>
          </div>

          <!-- Google Maps placeholder -->
          <div class="map-embed" aria-label="Carte de localisation de la boutique">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d60813.59289830117!2d-61.1247!3d14.6009!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8c61ea5cf0ad2d77%3A0x4a0e2d2c5bb21d7c!2sFort-de-France%2C%20Martinique!5e0!3m2!1sfr!2sfr!4v1700000000000"
              width="100%"
              height="240"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Localisation de Santé Tonique à Fort-de-France"
            ></iframe>
          </div>
        </div>

        <!-- Formulaire -->
        <div class="contact-form-wrap reveal">
          <h2>Envoyez-nous <em>un message</em></h2>
          <p class="form-intro">
            Vous avez une question sur un produit, un conseil santé ? N'hésitez pas à nous écrire.
          </p>

          <form class="contact-form" name="contact" method="POST" novalidate>
            <div class="form-field">
              <label for="nom" class="form-label">Nom complet <span aria-hidden="true">*</span></label>
              <input
                type="text"
                id="nom"
                name="nom"
                class="form-input"
                placeholder="Votre nom et prénom"
                required
                autocomplete="name"
              />
            </div>

            <div class="form-field">
              <label for="email" class="form-label">Adresse email <span aria-hidden="true">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                class="form-input"
                placeholder="votre@email.com"
                required
                autocomplete="email"
              />
            </div>

            <div class="form-field">
              <label for="message" class="form-label">Votre message <span aria-hidden="true">*</span></label>
              <textarea
                id="message"
                name="message"
                class="form-input form-textarea"
                placeholder="Décrivez votre demande..."
                rows="6"
                required
              ></textarea>
            </div>

            <button type="submit" class="btn-primary form-submit">
              Envoyer le message
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(135deg, #F5E6C8, #E8D09A);
    padding: calc(72px + 5rem) 5rem 4rem;
    text-align: center;
  }
  .page-hero__inner { max-width: 640px; margin: 0 auto; }
  .page-hero .eyebrow { justify-content: center; }
  .page-hero h1 { color: var(--bark); margin: 0.5rem 0 1rem; }
  .page-hero__sub {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.1rem;
    color: var(--terra);
    margin: 0;
  }

  /* Grid */
  .contact-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  /* Info column */
  .contact-info h2,
  .contact-form-wrap h2 {
    color: var(--bark);
    margin-bottom: 2rem;
  }

  .info-block {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    margin-bottom: 1.8rem;
  }
  .info-icon {
    width: 44px;
    height: 44px;
    background: linear-gradient(135deg, #F5E6C8, #E8D09A);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--honey);
    flex-shrink: 0;
    margin-top: 0.1rem;
  }
  .info-block strong {
    display: block;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--bark);
    margin-bottom: 0.3rem;
  }
  .info-block address,
  .info-block p {
    font-style: normal;
    font-size: 0.9rem;
    color: rgba(61, 43, 31, 0.75);
    margin: 0;
    line-height: 1.6;
  }
  .info-block a {
    font-size: 0.9rem;
    color: var(--honey);
    text-decoration: none;
    transition: color 0.2s;
  }
  .info-block a:hover { color: var(--terra); }

  .horaires {
    border-collapse: collapse;
    font-size: 0.88rem;
    color: rgba(61, 43, 31, 0.75);
  }
  .horaires td {
    padding: 0.2rem 1rem 0.2rem 0;
  }
  .horaires td:first-child {
    color: var(--bark);
    font-weight: 400;
  }

  .map-embed {
    margin-top: 2rem;
    border-radius: 3px;
    overflow: hidden;
    border: 1px solid rgba(200, 115, 42, 0.12);
  }

  /* Form */
  .form-intro {
    font-size: 0.9rem;
    color: rgba(61, 43, 31, 0.7);
    margin-bottom: 1.8rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-label {
    font-family: 'Jost', sans-serif;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--bark);
  }
  .form-label span { color: var(--honey); }

  .form-input {
    font-family: 'Jost', sans-serif;
    font-size: 0.9rem;
    font-weight: 300;
    color: var(--bark);
    background: var(--warm-white);
    border: 1.5px solid rgba(61, 43, 31, 0.15);
    border-radius: 2px;
    padding: 0.75rem 1rem;
    transition: border-color 0.25s;
    outline: none;
    width: 100%;
  }
  .form-input::placeholder { color: rgba(61, 43, 31, 0.35); }
  .form-input:focus { border-color: var(--honey); }

  .form-textarea {
    resize: vertical;
    min-height: 140px;
    line-height: 1.6;
  }

  .form-submit {
    align-self: flex-start;
    cursor: pointer;
  }

  @media (max-width: 900px) {
    .page-hero { padding: calc(72px + 3rem) 1.5rem 2.5rem; }
    .contact-grid { grid-template-columns: 1fr; gap: 3rem; }
  }
</style>
