---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';

// Import one image per product — replace with real product photos when available
import imgProduit1 from '../assets/products/aronia.png';
import imgProduit2 from '../assets/products/image_de_fond.png';
import imgProduit3 from '../assets/products/image_de_fond.png';
import imgProduit4 from '../assets/products/image_de_fond.png';
import imgProduit5 from '../assets/products/image_de_fond.png';

const produits = [
  {
    nom: "Jus d'Aronia",
    categorie: 'Alimentation bio & diététique',
    description: "Un jus concentré d'aronia aux puissantes propriétés antioxydantes, idéal au quotidien.",
    descriptionLongue: `L'aronia (Aronia melanocarpa) est l'un des fruits les plus riches en antioxydants connus à ce jour. Originaire d'Amérique du Nord, il est aujourd'hui reconnu pour ses multiples bienfaits sur la santé.\n\nRiche en polyphénols, flavonoïdes et vitamines C et K, le jus d'aronia soutient le système immunitaire, protège les cellules du stress oxydatif et contribue à une bonne circulation sanguine.\n\nConseils d'utilisation : 30 à 50 ml par jour, pur ou dilué dans de l'eau ou un autre jus. À consommer de préférence le matin.`,
    image: imgProduit1,
  },
  {
    nom: 'Produit 2',
    categorie: 'Compléments alimentaires',
    description: 'Enrichi en vitamines et minéraux essentiels pour renforcer vos défenses naturelles.',
    descriptionLongue: `Ce complément alimentaire a été formulé pour répondre aux besoins quotidiens en micronutriments essentiels. Il associe vitamines et minéraux soigneusement dosés pour un soutien optimal de l'organisme.\n\nParmi ses bienfaits : soutien du système immunitaire, réduction de la fatigue, contribution au bon fonctionnement du métabolisme énergétique.\n\nConseils d'utilisation : selon les indications du fabricant, de préférence au cours d'un repas.`,
    image: imgProduit2,
  },
  {
    nom: 'Produit 3',
    categorie: 'Alimentation bio & diététique',
    description: "Certifié bio, ce produit s'intègre dans une alimentation saine et équilibrée.",
    descriptionLongue: `Issu de l'agriculture biologique certifiée, ce produit garantit une composition sans pesticides de synthèse, sans OGM et sans additifs inutiles. Sa fabrication respecte des méthodes traditionnelles qui préservent au mieux les qualités nutritionnelles des ingrédients.\n\nIdéal pour enrichir votre alimentation quotidienne avec des nutriments d'origine naturelle, il convient aux personnes souhaitant adopter une démarche alimentaire plus saine et plus consciente.\n\nConservation : à l'abri de la chaleur et de l'humidité.`,
    image: imgProduit3,
  },
  {
    nom: 'Produit 4',
    categorie: 'Alimentation bio & diététique',
    description: "Un aliment bio de qualité supérieure, respectueux des traditions et de l'environnement.",
    descriptionLongue: `Sélectionné pour sa qualité exceptionnelle et son respect des méthodes de production durables, ce produit bio s'inscrit dans une démarche de consommation responsable adaptée au contexte martiniquais.\n\nSa composition naturelle et non transformée en fait un aliment de choix pour ceux qui souhaitent prendre soin de leur santé tout en préservant leur environnement local.\n\nSuggestion d'utilisation : intégrez-le facilement à vos recettes ou consommez-le tel quel pour profiter de toutes ses qualités nutritionnelles.`,
    image: imgProduit4,
  },
  {
    nom: 'Produit 5',
    categorie: 'Cosmétiques naturels',
    description: 'Soin naturel formulé sans parabènes ni produits chimiques agressifs.',
    descriptionLongue: `Ce soin cosmétique naturel a été conçu pour respecter la peau et l'environnement. Sa formulation, exempte de parabènes, de sulfates agressifs et de silicones, s'appuie sur des ingrédients d'origine végétale soigneusement sélectionnés.\n\nAdapté aux peaux sensibles et aux conditions climatiques des Antilles — chaleur, humidité et exposition solaire intense — il hydrate, protège et nourrit en profondeur sans alourdir.\n\nMode d'emploi : appliquer sur peau propre et sèche en massant doucement. Résultats visibles après utilisation régulière.`,
    image: imgProduit5,
  },
];

const categories = ['Compléments alimentaires', 'Alimentation bio & diététique', 'Cosmétiques naturels'];
---

<BaseLayout
  title="Nos produits"
  description="Découvrez notre sélection de produits diététiques, compléments alimentaires, alimentation bio et cosmétiques naturels à Fort-de-France."
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="page-hero__inner">
      <div class="eyebrow">Ce que nous proposons</div>
      <h1>Nos <em>produits naturels</em></h1>
      <p class="page-hero__sub">
        Une sélection soigneuse de produits pour votre santé et votre bien-être.
      </p>
    </div>
  </section>

  <!-- Catégories -->
  <section class="section section--warm">
    <div class="container">
      <div class="cats-grid reveal">
        {categories.map((cat) => (
          <div class="cat-badge">
            <span class="accent">✦</span> {cat}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Liste des produits -->
  <section class="section">
    <div class="container">
      <div class="produits-intro reveal">
        <div class="eyebrow">Notre sélection</div>
        <h2>5 produits <em>pour prendre soin de vous</em></h2>
        <p class="produits-note">
          N'hésitez pas à nous appeler ou à passer en boutique pour toute question.
        </p>
      </div>

      <div class="produits-grid">
        {produits.map((produit, i) => (
          <article class="produit-card reveal">
            <div class="produit-card__image">
              <Image
                src={produit.image}
                alt={`Photo de ${produit.nom}`}
                width={400}
                height={458}
              />
            </div>
            <div class="produit-card__body">
              <span class="produit-badge">{produit.categorie}</span>
              <h3>{produit.nom}</h3>
              <p>{produit.description}</p>
              <button
                class="lire-plus-btn"
                data-index={i}
                aria-label={`En savoir plus sur ${produit.nom}`}
              >
                Lire plus
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
              </button>
            </div>
          </article>
        ))}
      </div>

      <!-- CTA contact -->
      <div class="produits-cta reveal">
        <p class="tagline">Une question sur un produit ? Contactez-nous directement.</p>
        <a href="/contact" class="btn-primary">Nous contacter</a>
      </div>
    </div>
  </section>

  <!-- Modals -->
  {produits.map((produit, i) => (
    <div class="modal" id={`modal-${i}`} role="dialog" aria-modal="true" aria-label={produit.nom} hidden>
      <div class="modal__backdrop"></div>
      <div class="modal__panel">
        <button class="modal__close" aria-label="Fermer">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
        <div class="modal__inner">
          <div class="modal__image">
            <Image
              src={produit.image}
              alt={`Photo de ${produit.nom}`}
              width={400}
              height={458}
            />
          </div>
          <div class="modal__content">
            <span class="produit-badge">{produit.categorie}</span>
            <h2>{produit.nom}</h2>
            <div class="modal__long-desc">
              {produit.descriptionLongue.split('\n\n').map((para) => (
                <p>{para}</p>
              ))}
            </div>
            <a href="/contact" class="btn-primary">Nous contacter</a>
          </div>
        </div>
      </div>
    </div>
  ))}
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(135deg, #F5E6C8, #E8D09A);
    padding: calc(72px + 5rem) 5rem 4rem;
    text-align: center;
  }
  .page-hero__inner { max-width: 680px; margin: 0 auto; }
  .page-hero .eyebrow { justify-content: center; }
  .page-hero h1 { color: var(--bark); margin: 0.5rem 0 1rem; }
  .page-hero__sub {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.1rem;
    color: var(--terra);
    margin: 0;
  }

  /* Categories strip */
  .cats-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }
  .cat-badge {
    background: rgba(61, 43, 31, 0.08);
    border: 1px solid rgba(61, 43, 31, 0.15);
    padding: 0.5rem 1.2rem;
    border-radius: 2px;
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--bark);
  }
  .accent { color: var(--honey); }

  /* Products intro */
  .produits-intro {
    max-width: 600px;
    margin: 0 auto 3rem;
    text-align: center;
  }
  .produits-intro .eyebrow { justify-content: center; }
  .produits-intro h2 { color: var(--bark); margin-bottom: 0.6rem; }
  .produits-note {
    font-size: 0.88rem;
    color: rgba(61, 43, 31, 0.6);
    margin: 0;
    font-style: italic;
  }

  /* Products grid */
  .produits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .produit-card {
    background: var(--warm-white);
    border: 1px solid rgba(200, 115, 42, 0.1);
    border-radius: 3px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  .produit-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(61, 43, 31, 0.1);
  }

  .produit-card__image {
    overflow: hidden;
    height: 280px;
    display: flex;
    justify-content: center;
  }
  .produit-card__image img {
    width: auto;
    height: 100%;
    object-fit: contain;
    transition: transform 0.4s ease;
  }
  .produit-card:hover .produit-card__image img {
    transform: scale(1.03);
  }

  .produit-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .produit-badge {
    display: inline-block;
    background: rgba(122, 140, 94, 0.12);
    color: var(--sage);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border-radius: 2px;
    margin-bottom: 0.7rem;
    align-self: flex-start;
  }

  .produit-card__body h3 {
    font-size: 1.1rem;
    color: var(--bark);
    margin-bottom: 0.5rem;
  }

  .produit-card__body > p {
    font-size: 0.88rem;
    color: rgba(61, 43, 31, 0.7);
    line-height: 1.65;
    margin: 0 0 1.2rem;
    flex: 1;
  }

  .lire-plus-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: 'Jost', sans-serif;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--honey);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    align-self: flex-start;
    transition: gap 0.2s;
  }
  .lire-plus-btn:hover { gap: 0.6rem; }

  /* CTA */
  .produits-cta {
    text-align: center;
    padding: 3rem;
    background: linear-gradient(135deg, var(--cream), #EDD5A3);
    border-radius: 3px;
  }
  .tagline {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.3rem;
    color: var(--bark);
    margin-bottom: 1.5rem;
  }

  /* ===== MODAL ===== */
  .modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }
  .modal[hidden] { display: none; }

  .modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(61, 43, 31, 0.55);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .modal__panel {
    position: relative;
    background: var(--ivory);
    border-radius: 3px;
    max-width: 860px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    opacity: 0;
    transform: translateY(24px) scale(0.98);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }

  .modal.is-open .modal__backdrop { opacity: 1; }
  .modal.is-open .modal__panel {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .modal__close {
    position: absolute;
    top: 1.2rem;
    right: 1.2rem;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(61, 43, 31, 0.07);
    border: none;
    border-radius: 50%;
    color: var(--bark);
    cursor: pointer;
    z-index: 1;
    transition: background 0.2s;
  }
  .modal__close:hover { background: rgba(61, 43, 31, 0.14); }

  .modal__inner {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
  }

  .modal__image {
    background: linear-gradient(135deg, #F5E6C8, #EDD5A3);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    min-height: 360px;
  }
  .modal__image img {
    width: auto;
    max-height: 340px;
    object-fit: contain;
  }

  .modal__content {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .modal__content h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--bark);
    margin: 0.3rem 0 0;
  }
  .modal__long-desc { flex: 1; }
  .modal__long-desc p {
    font-size: 0.9rem;
    color: rgba(61, 43, 31, 0.75);
    line-height: 1.8;
    margin-bottom: 0.8em;
  }
  .modal__long-desc p:last-child { margin-bottom: 0; }

  @media (max-width: 900px) {
    .page-hero { padding: calc(72px + 3rem) 1.5rem 2.5rem; }
    .produits-grid { grid-template-columns: 1fr; }
    .modal__inner { grid-template-columns: 1fr; }
    .modal__image { min-height: 220px; padding: 1.5rem; }
    .modal__image img { max-height: 200px; }
    .modal__content { padding: 1.5rem; }
  }
  @media (min-width: 600px) and (max-width: 900px) {
    .produits-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script>
  function initModals() {
    const modals = document.querySelectorAll<HTMLElement>('.modal');

    function openModal(modal: HTMLElement) {
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => {
        requestAnimationFrame(() => modal.classList.add('is-open'));
      });
      modal.querySelector<HTMLElement>('.modal__close')?.focus();
    }

    function closeModal(modal: HTMLElement) {
      modal.classList.remove('is-open');
      document.body.style.overflow = '';
      modal.addEventListener('transitionend', () => {
        modal.hidden = true;
      }, { once: true });
    }

    document.querySelectorAll<HTMLButtonElement>('.lire-plus-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const modal = document.getElementById(`modal-${btn.dataset.index}`);
        if (modal) openModal(modal);
      });
    });

    modals.forEach((modal) => {
      modal.querySelector('.modal__close')?.addEventListener('click', () => closeModal(modal));
      modal.querySelector('.modal__backdrop')?.addEventListener('click', () => closeModal(modal));
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        const open = document.querySelector<HTMLElement>('.modal.is-open');
        if (open) closeModal(open);
      }
    });
  }

  document.addEventListener('astro:page-load', initModals);
</script>
