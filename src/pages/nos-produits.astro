---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import imageDeFond from '../assets/products/image_de_fond.png';

const produits = [
  {
    nom: 'Produit 1',
    categorie: 'Compléments alimentaires',
    description:
      'Un complément alimentaire soigneusement sélectionné pour soutenir votre vitalité au quotidien. Formulé à partir d\'ingrédients d\'origine naturelle.',
  },
  {
    nom: 'Produit 2',
    categorie: 'Compléments alimentaires',
    description:
      'Enrichi en vitamines et minéraux essentiels, ce produit accompagne votre organisme et renforce vos défenses naturelles.',
  },
  {
    nom: 'Produit 3',
    categorie: 'Alimentation bio & diététique',
    description:
      'Certifié bio, ce produit diététique s\'intègre facilement dans une alimentation saine et équilibrée. Sans additifs inutiles.',
  },
  {
    nom: 'Produit 4',
    categorie: 'Alimentation bio & diététique',
    description:
      'Un aliment bio de qualité supérieure, respectueux des méthodes traditionnelles et de l\'environnement martiniquais.',
  },
  {
    nom: 'Produit 5',
    categorie: 'Cosmétiques naturels',
    description:
      'Soin naturel pour la peau, formulé sans parabènes ni produits chimiques agressifs. Respectueux de votre peau et de la nature.',
  },
];

const categories = ['Compléments alimentaires', 'Alimentation bio & diététique', 'Cosmétiques naturels'];
---

<BaseLayout
  title="Nos produits"
  description="Découvrez notre sélection de produits diététiques, compléments alimentaires, alimentation bio et cosmétiques naturels à Fort-de-France."
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="page-hero__inner">
      <div class="eyebrow">Ce que nous proposons</div>
      <h1>Nos <em>produits naturels</em></h1>
      <p class="page-hero__sub">
        Une sélection soigneuse de produits pour votre santé et votre bien-être.
      </p>
    </div>
  </section>

  <!-- Catégories -->
  <section class="section section--warm">
    <div class="container">
      <div class="cats-grid reveal">
        {categories.map((cat) => (
          <div class="cat-badge">
            <span class="accent">✦</span> {cat}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Liste des produits -->
  <section class="section">
    <div class="container">
      <div class="produits-intro reveal">
        <div class="eyebrow">Notre sélection</div>
        <h2>5 produits <em>pour prendre soin de vous</em></h2>
        <p class="produits-note">
          Les photos et noms définitifs de nos produits seront disponibles très prochainement.
          N'hésitez pas à nous appeler ou à passer en boutique pour toute question.
        </p>
      </div>

      <div class="produits-grid">
        {produits.map((produit) => (
          <article class="produit-card reveal">
            <div class="produit-card__image">
              <Image
                src={imageDeFond}
                alt={`Photo de ${produit.nom}`}
                width={400}
                height={300}
              />
            </div>
            <div class="produit-card__body">
              <span class="produit-badge">{produit.categorie}</span>
              <h3>{produit.nom}</h3>
              <p>{produit.description}</p>
            </div>
          </article>
        ))}
      </div>

      <!-- CTA contact -->
      <div class="produits-cta reveal">
        <p class="tagline">Une question sur un produit ? Contactez-nous directement.</p>
        <a href="/contact" class="btn-primary">Nous contacter</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(135deg, #F5E6C8, #E8D09A);
    padding: calc(72px + 5rem) 5rem 4rem;
    text-align: center;
  }
  .page-hero__inner { max-width: 680px; margin: 0 auto; }
  .page-hero .eyebrow { justify-content: center; }
  .page-hero h1 { color: var(--bark); margin: 0.5rem 0 1rem; }
  .page-hero__sub {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.1rem;
    color: var(--terra);
    margin: 0;
  }

  /* Categories strip */
  .cats-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }
  .cat-badge {
    background: rgba(61, 43, 31, 0.08);
    border: 1px solid rgba(61, 43, 31, 0.15);
    padding: 0.5rem 1.2rem;
    border-radius: 2px;
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--bark);
  }
  .accent { color: var(--honey); }

  /* Products intro */
  .produits-intro {
    max-width: 600px;
    margin: 0 auto 3rem;
    text-align: center;
  }
  .produits-intro .eyebrow { justify-content: center; }
  .produits-intro h2 { color: var(--bark); margin-bottom: 0.6rem; }
  .produits-note {
    font-size: 0.88rem;
    color: rgba(61, 43, 31, 0.6);
    margin: 0;
    font-style: italic;
  }

  /* Products grid */
  .produits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .produit-card {
    background: var(--warm-white);
    border: 1px solid rgba(200, 115, 42, 0.1);
    border-radius: 3px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .produit-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(61, 43, 31, 0.1);
  }

  .produit-card__image {
    overflow: hidden;
    height: 220px;
  }
  .produit-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .produit-card:hover .produit-card__image img {
    transform: scale(1.03);
  }

  .produit-card__body {
    padding: 1.5rem;
  }

  .produit-badge {
    display: inline-block;
    background: rgba(122, 140, 94, 0.12);
    color: var(--sage);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border-radius: 2px;
    margin-bottom: 0.7rem;
  }

  .produit-card__body h3 {
    font-size: 1.1rem;
    color: var(--bark);
    margin-bottom: 0.5rem;
  }

  .produit-card__body p {
    font-size: 0.88rem;
    color: rgba(61, 43, 31, 0.7);
    line-height: 1.65;
    margin: 0;
  }

  /* CTA */
  .produits-cta {
    text-align: center;
    padding: 3rem;
    background: linear-gradient(135deg, var(--cream), #EDD5A3);
    border-radius: 3px;
  }
  .tagline {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.3rem;
    color: var(--bark);
    margin-bottom: 1.5rem;
  }

  @media (max-width: 900px) {
    .page-hero { padding: calc(72px + 3rem) 1.5rem 2.5rem; }
    .produits-grid { grid-template-columns: 1fr; }
  }
  @media (min-width: 600px) and (max-width: 900px) {
    .produits-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
