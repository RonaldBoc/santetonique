---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function formatDate(date: Date) {
  return new Intl.DateTimeFormat('fr-FR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(date);
}
---

<BaseLayout
  title="Blog"
  description="Articles santé, bien-être et actualités de la boutique Santé Tonique — Fort-de-France, Martinique."
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="page-hero__inner">
      <div class="eyebrow">Conseils & actualités</div>
      <h1>Le blog <em>Santé Tonique</em></h1>
      <p class="page-hero__sub">
        Santé, bien-être et nouvelles de notre boutique.
      </p>
    </div>
  </section>

  <!-- Articles -->
  <section class="section">
    <div class="container">
      {posts.length === 0 ? (
        <p class="no-posts">Aucun article pour le moment. Revenez bientôt !</p>
      ) : (
        <div class="blog-grid">
          {posts.map((post) => (
            <article class="blog-card reveal">
              {post.data.heroImage && (
                <a href={`/blog/${post.id}/`} class="blog-card__image" aria-hidden="true" tabindex="-1">
                  <Image
                    src={post.data.heroImage}
                    alt=""
                    width={720}
                    height={360}
                  />
                </a>
              )}
              <div class="blog-card__body">
                <div class="blog-card__meta">
                  <span class="blog-card__category">{post.data.category}</span>
                  <time datetime={post.data.pubDate.toISOString()}>
                    {formatDate(post.data.pubDate)}
                  </time>
                </div>
                <h2 class="blog-card__title">
                  <a href={`/blog/${post.id}/`}>{post.data.title}</a>
                </h2>
                <p class="blog-card__excerpt">{post.data.excerpt}</p>
                <a href={`/blog/${post.id}/`} class="blog-card__link">
                  Lire la suite
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(135deg, #F5E6C8, #E8D09A);
    padding: calc(72px + 5rem) 5rem 4rem;
    text-align: center;
  }
  .page-hero__inner { max-width: 600px; margin: 0 auto; }
  .page-hero .eyebrow { justify-content: center; }
  .page-hero h1 { color: var(--bark); margin: 0.5rem 0 1rem; }
  .page-hero__sub {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.1rem;
    color: var(--terra);
    margin: 0;
  }

  .no-posts {
    text-align: center;
    color: rgba(61, 43, 31, 0.55);
    font-style: italic;
    padding: 3rem 0;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .blog-card {
    background: var(--warm-white);
    border: 1px solid rgba(200, 115, 42, 0.1);
    border-radius: 3px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(61, 43, 31, 0.1);
  }

  .blog-card__image {
    display: block;
    overflow: hidden;
    height: 220px;
  }
  .blog-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .blog-card:hover .blog-card__image img {
    transform: scale(1.03);
  }

  .blog-card__body {
    padding: 1.5rem;
  }

  .blog-card__meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.7rem;
  }

  .blog-card__category {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sage);
    background: rgba(122, 140, 94, 0.1);
    padding: 0.25rem 0.6rem;
    border-radius: 2px;
  }

  .blog-card__meta time {
    font-size: 0.8rem;
    color: rgba(61, 43, 31, 0.5);
  }

  .blog-card__title {
    font-size: 1.2rem;
    margin-bottom: 0.6rem;
    line-height: 1.3;
  }
  .blog-card__title a {
    color: var(--bark);
    text-decoration: none;
    transition: color 0.2s;
  }
  .blog-card__title a:hover { color: var(--honey); }

  .blog-card__excerpt {
    font-size: 0.88rem;
    color: rgba(61, 43, 31, 0.7);
    line-height: 1.65;
    margin-bottom: 1.2rem;
  }

  .blog-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--honey);
    text-decoration: none;
    transition: gap 0.2s;
  }
  .blog-card__link:hover { gap: 0.6rem; }

  @media (max-width: 900px) {
    .page-hero { padding: calc(72px + 3rem) 1.5rem 2.5rem; }
    .blog-grid { grid-template-columns: 1fr; }
  }
</style>
