---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, excerpt, pubDate, category, heroImage } = Astro.props;

function formatDate(date: Date) {
  return new Intl.DateTimeFormat('fr-FR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(date);
}
---

<BaseLayout title={title} description={excerpt}>
  <article class="blog-article">
    {heroImage && (
      <div class="blog-article__hero">
        <Image
          src={heroImage}
          alt=""
          width={1200}
          height={500}
        />
      </div>
    )}

    <div class="blog-article__header">
      <div class="blog-article__meta">
        {category && <span class="article-category">{category}</span>}
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
      </div>
      <h1>{title}</h1>
      {excerpt && <p class="article-excerpt">{excerpt}</p>}
    </div>

    <div class="blog-article__body prose">
      <slot />
    </div>

    <div class="blog-article__back">
      <a href="/blog" class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
        Retour au blog
      </a>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-article {
    padding-top: 72px;
    max-width: 820px;
    margin: 0 auto;
    padding-left: 2rem;
    padding-right: 2rem;
    padding-bottom: 5rem;
  }

  .blog-article__hero {
    margin: 0 -2rem 0;
    overflow: hidden;
    max-height: 480px;
  }
  .blog-article__hero img {
    width: 100%;
    height: 480px;
    object-fit: cover;
  }

  .blog-article__header {
    padding: 3rem 0 2rem;
    border-bottom: 1px solid rgba(61, 43, 31, 0.1);
    margin-bottom: 2.5rem;
  }

  .blog-article__meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .article-category {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sage);
    background: rgba(122, 140, 94, 0.1);
    padding: 0.28rem 0.7rem;
    border-radius: 2px;
  }

  .blog-article__meta time {
    font-size: 0.85rem;
    color: rgba(61, 43, 31, 0.5);
  }

  .blog-article__header h1 {
    color: var(--bark);
    margin-bottom: 0.8rem;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
  }

  .article-excerpt {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.15rem;
    color: var(--terra);
    line-height: 1.6;
    margin: 0;
  }

  .blog-article__back {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(61, 43, 31, 0.1);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--honey);
    text-decoration: none;
    transition: gap 0.2s;
  }
  .back-link:hover { gap: 0.2rem; }

  @media (max-width: 900px) {
    .blog-article { padding-left: 1.5rem; padding-right: 1.5rem; }
    .blog-article__hero { margin: 0 -1.5rem; }
    .blog-article__hero img { height: 260px; }
  }
</style>
